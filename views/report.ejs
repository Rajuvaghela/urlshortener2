<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <%- include('header') %>
    <h1>My report card</h1>

   <section>
     <ul>
        <% students.map((stud)=>{ %>

            <li>
                <p>Name: <%= stud.name %>
                </p>
                <p>Grade: <%= stud.grade %>
                </p>
                <p>Favourite Sub: <%= stud.favouriteSub %>
                </p>
            </li>
            <% }) %>
    </ul>
   </section>

</body>

</html>